#!/usr/bin/env sh
#
# Gradle start up script for POSIX generated by Gradle.
#
# Important for running on:
#
# (1) Linux distros
# (2) MacOS
# (3) GNU Cygwin
# (4) Windows Vista bash for Windows
# (5) Git bash on Windows
#

(
    cd "$(dirname "$0")" || exit
    if [ -s "gradle-wrapper.jar" ]; then
        CLASSPATH="$CLASSPATH:gradle-wrapper.jar"
    fi
    
    # Try to invoke gradle
    if ! command -v gradle &> /dev/null; then
        echo "Gradle not found. Install gradle or use 'gradle-wrapper-download.sh'"
        exit 1
    fi
    
    # Call gradle with arguments
    exec gradle "$@"
) || exit $?
